#!/bin/sh

# Maven Wrapper Start Script
# For Git Bash on Windows

# Locate Java - try installed JDK first, then fall back to JAVA_HOME env
if [ -z "$JAVA_HOME" ]; then
  JAVA_HOME="/c/Program Files/Microsoft/jdk-17.0.19.10-hotspot"
fi

# Determine the Maven Wrapper base dir
PRG="$0"
while [ -h "$PRG" ]; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null

CLASSPATH=$APP_HOME/.mvn/wrapper/maven-wrapper.jar
MAVEN_OPTS=""
MAVEN_CMD_LINE_ARGS="$@"

export M2_HOME="${M2_HOME:-}"

exec "$JAVA_HOME/bin/java.exe" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$CLASSPATH" \
  "-Dmaven.home=${M2_HOME}" \
  "-Dmaven.multiModuleProjectDirectory=${APP_HOME}" \
  org.apache.maven.wrapper.MavenWrapperMain \
  $MAVEN_CMD_LINE_ARGS
